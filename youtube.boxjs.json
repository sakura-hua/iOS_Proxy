{
  "id": "maasea.youtube.config",
  "name": "YouTube 增强配置 (Maasea)",
  "author": "@Maasea",
  "icon": "https://raw.githubusercontent.com/Koolson/Qure/master/IconSet/Color/YouTube.png",
  "repo": "https://github.com/Maasea/sgmodule",
  "apps": [
    {
      "id": "youtube.enhance",
      "name": "YouTube 去广告与增强",
      "keys": [
        "blockUpload",
        "blockImmersive",
        "blockShorts",
        "captionLang",
        "debug"
      ],
      "settings": [
        {
          "id": "blockUpload",
          "name": "屏蔽上传按钮",
          "val": true,
          "type": "boolean",
          "desc": "开启后屏蔽底部的上传（+）按钮。"
        },
        {
          "id": "blockImmersive",
          "name": "屏蔽选段按钮",
          "val": true,
          "type": "boolean",
          "desc": "开启后屏蔽视频下方的选段按钮。"
        },
        {
          "id": "blockShorts",
          "name": "屏蔽 Shorts 按钮",
          "val": true,
          "type": "boolean",
          "desc": "开启后屏蔽底部导航栏的 Shorts 短视频按钮。"
        },
        {
          "id": "captionLang",
          "name": "字幕翻译语言",
          "val": "off",
          "type": "text",
          "desc": "语言代码遵循 Google Translate Languages Codes (如 zh-Hans, zh-Hant)。当填入 off 时关闭翻译。"
        },
        {
          "id": "debug",
          "name": "启用调试模式",
          "val": false,
          "type": "boolean",
          "desc": "开启调试模式用于输出更多日志。"
        }
      ],
      "author": "@Maasea",
      "repo": "https://github.com/Maasea/sgmodule",
      "script": "https://raw.githubusercontent.com/Maasea/sgmodule/refs/heads/master/Script/Youtube/youtube.response.js"
    }
  ]
}
